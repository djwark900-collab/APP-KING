rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Model Validation
    function isValidUser(data) {
      return (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 256)) &&
             (!('photoURL' in data) || (data.photoURL == null || data.photoURL is string)) &&
             (!('score' in data) || data.score is number) &&
             (!('level' in data) || data.level is number) &&
             (!('rpLevel' in data) || data.rpLevel is number) &&
             (!('money' in data) || data.money is number);
    }

    function isValidAsset(data) {
       return data.id is string &&
              data.name is string &&
              data.cost is number;
    }

    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == 'traleague@gmail.com' || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    // Match users collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Leaderboard traversal
      
      allow create: if isOwner(userId) && isValidUser(incoming());

      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) &&
                      (!('uid' in incoming()) || !('uid' in existing()) || incoming().uid == existing().uid) &&
                      (!('email' in incoming()) || !('email' in existing()) || incoming().email == existing().email);
      
      allow delete: if isAdmin();
    }

    // Frames & Skins
    match /frames/{frameId} {
      allow read: if true;
      allow write: if isAdmin() && isValidAsset(incoming()); 
      allow delete: if isAdmin();
    }

    match /skins/{skinId} {
      allow read: if true;
      allow write: if isAdmin() && isValidAsset(incoming()); 
      allow delete: if isAdmin();
    }

    // Admins collection (read-only for security check)
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Royal Pass Rewards collection
    match /rp_rewards/{rewardId} {
      allow read: if true;
      allow write: if isAdmin();
      
      function isValidReward(data) {
        return data.level is number &&
               data.name is string &&
               data.type is string &&
               (!('image' in data) || (data.image is string && data.image.size() <= 1048576)) &&
               (!('color' in data) || (data.color is string && data.color.size() <= 7));
      }
    }

    // App Creator Info
    match /app_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
